        {
          "type": "priority_round",
          "players": ["p1", "p2"],
          "result": "all_pass",
          "note": "CR 116.3a: p1 (active) passes, then p2 passes. Empty stack → step advances to BeginningOfCombat."
        },
        {
          "type": "assert_state",
          "description": "After all-pass: stack still empty, life totals unchanged",
          "assertions": {
            "zones.stack": { "is_empty": true },
            "players.p1.life": 40,
            "players.p2.life": 40
